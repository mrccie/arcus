{
  "rpicam-apps": {
    "lores": { "width": 640, "height": 640, "format": "rgb" }
  },

  "hailo_yolo_inference": {
    "hef_file_10": "/usr/share/hailo-models/yolov8m_h10.hef",
    "hef_file_8L": "/usr/share/hailo-models/yolov8s_h8l.hef",
